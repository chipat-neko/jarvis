# ====================================================================
# Jarvis — .env.example
# Modèle de variables d'environnement à dupliquer en `.env` (gitignored).
#
# ⚠️ PRÉFÈRE LE KEYRING OS pour les vrais secrets en prod.
# Le .env est OK pour dev rapide, mais le keyring est plus sûr
# (chiffrement OS, pas de risque de commit accidentel).
#
# Exemple keyring :
#   python -c "import keyring; keyring.set_password('jarvis','anthropic_api_key','sk-ant-...')"
# ====================================================================

# --- Anthropic Claude ---
# Récupère ta clé sur https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXX

# --- Ollama (local, pas de clé en général) ---
# OLLAMA_HOST=http://localhost:11434

# --- Home Assistant (long-lived access token) ---
# HA_URL=http://homeassistant.local:8123
# HA_TOKEN=eyJhbGciOiJIUzI1NiI...

# --- GitHub MCP ---
# GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXXXXXX

# --- Brave Search MCP ---
# BRAVE_API_KEY=BSA-XXXXXXXXXXXXXXXXXXXXXXXX

# --- Spotify MCP ---
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# --- Gmail / Notion MCP : OAuth, pas de clé statique ---

# --- LangSmith observability (optionnel, Phase 9) ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_pt_XXXXXXXXXXXXXXXXXXXXXXXX
# LANGCHAIN_PROJECT=jarvis

# --- Environnement ---
JARVIS_ENV=dev                 # dev | staging | prod
JARVIS_CONFIG=config/local.yaml
